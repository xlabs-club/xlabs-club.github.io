&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;ClickHouse&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;bitnami/clickhouse&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;&lt;a href="https://github.com/Altinity/clickhouse-operator" target="_blank" rel="noopener"&gt;clickhouse-operator&lt;/a&gt;
（Altinity 维护）&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;h3 id="消息队列"&gt;消息队列&lt;/h3&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;中间件&lt;/th&gt;
